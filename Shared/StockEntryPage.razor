@using WarehouseApp.Services
@using WarehouseApp.Models
@inject WarehouseService Warehouse
@inject AuthService Auth

<div class="page-header"><h2>⬆️ ورود مواد به انبار</h2></div>

<div class="form-card">
    <div class="form-grid">
        <div class="form-group">
            <label>ماده اولیه *</label>
            <select value="@selId" @onchange="OnMaterialChange" class="form-input">
                <option value="0">انتخاب کنید...</option>
                @foreach (var m in materials) { <option value="@m.Id">[@m.Code] @m.Name (@m.Unit)</option> }
            </select>
        </div>
        <div class="form-group">
            <label>مقدار *</label>
            <input @bind="qty" type="number" step="0.01" class="form-input" />
        </div>
        @if (Auth.CanViewPrice)
        {
            <div class="form-group">
                <label>قیمت واحد (ریال) *</label>
                <input @bind="price" type="number" class="form-input" />
            </div>
        }
        <div class="form-group">
            <label>تاریخ ورود *</label>
            <PersianDatePicker Value="@entryDate" ValueChanged="@(d => entryDate = d)" Placeholder="1403/01/15" />
        </div>
        <div class="form-group">
            <label>تاریخ انقضا *</label>
            <PersianDatePicker Value="@expiryDate" ValueChanged="@(d => expiryDate = d)" Placeholder="1403/07/15" />
        </div>
        <div class="form-group">
            <label>توضیحات</label>
            <input @bind="notes" class="form-input" />
        </div>
    </div>
    @if (!string.IsNullOrEmpty(ok))  { <div class="alert alert-success">@ok</div> }
    @if (!string.IsNullOrEmpty(err)) { <div class="alert alert-error">@err</div> }
    <div class="form-actions">
        <button class="btn btn-primary" @onclick="Submit">✅ ثبت ورودی</button>
        <button class="btn btn-secondary" @onclick="Reset">پاک کردن</button>
    </div>
</div>

@if (entries.Any())
{
    <div class="section-title">آخرین ورودی‌ها</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr><th>کد</th><th>ماده</th><th>مقدار</th>
                @if (Auth.CanViewPrice) { <th>قیمت</th> }
                <th>تاریخ ورود</th><th>تاریخ انقضا</th><th>ثبت‌کننده</th></tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr class="@(e.ExpiryDate < DateTime.Now ? "row-warning" : "")">
                        <td><code>@e.Material?.Code</code></td>
                        <td>@e.Material?.Name</td>
                        <td>@e.Quantity.ToString("N2") @e.Material?.Unit</td>
                        @if (Auth.CanViewPrice) { <td>@e.PricePerUnit.ToString("N0") ﷼</td> }
                        <td>@e.EntryDate.ToShamsi()</td>
                        <td class="@(e.ExpiryDate < DateTime.Now ? "expired" : e.ExpiryDate < DateTime.Now.AddDays(7) ? "expiring" : "")">
                            @e.ExpiryDate.ToShamsi()
                        </td>
                        <td>@e.CreatedByUsername</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    List<Material> materials = new(); List<StockEntry> entries = new();
    int selId = 0; decimal qty = 0, price = 0; string notes = "", ok = "", err = "";
    DateTime entryDate = DateTime.Today, expiryDate = DateTime.Today.AddMonths(6);

    protected override async Task OnInitializedAsync()
    {
        materials = await Warehouse.GetMaterialsAsync();
        entries = await Warehouse.GetEntriesAsync();
    }

    void OnMaterialChange(ChangeEventArgs e) =>
        selId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;

    async Task Submit()
    {
        ok = ""; err = "";
        if (selId == 0) { err = "ماده را انتخاب کنید"; return; }
        if (qty <= 0)   { err = "مقدار باید بیشتر از صفر باشد"; return; }
        if (Auth.CanViewPrice && price <= 0) { err = "قیمت باید بیشتر از صفر باشد"; return; }

        await Warehouse.AddStockEntryAsync(new StockEntry
        {
            MaterialId = selId, Quantity = qty, PricePerUnit = price,
            EntryDate = entryDate, ExpiryDate = expiryDate, Notes = notes,
            CreatedByUserId = Auth.CurrentUser!.Id, CreatedByUsername = Auth.CurrentUser.Username
        });
        var m = materials.FirstOrDefault(x => x.Id == selId);
        ok = $"✅ {qty} {m?.Unit} از [{m?.Code}] {m?.Name} در تاریخ {entryDate.ToShamsi()} ثبت شد";
        materials = await Warehouse.GetMaterialsAsync();
        entries = await Warehouse.GetEntriesAsync();
        Reset();
    }

    void Reset()
    {
        selId = 0; qty = 0; price = 0;
        entryDate = DateTime.Today; expiryDate = DateTime.Today.AddMonths(6); notes = "";
    }
}
