@using WarehouseApp.Services
@using WarehouseApp.Models
@inject WarehouseService Warehouse
@inject AuthService Auth
@inject IJSRuntime JS

<div class="page-header">
    <h2>📋 تاریخچه</h2>
    <button class="btn btn-success btn-sm" @onclick="ExportCsv">📥 CSV</button>
</div>

<div class="tabs">
    <button class="tab @(tab=="entries"?"active":"")"     @onclick='()=>tab="entries"'>ورودی‌ها (@entries.Count)</button>
    <button class="tab @(tab=="withdrawals"?"active":"")" @onclick='()=>tab="withdrawals"'>خروجی‌ها (@withdrawals.Count)</button>
</div>

<div class="search-bar">
    <input value="@search" @oninput="OnSearch" class="form-input search-input" placeholder="🔍 جستجو..." />
</div>

@if (tab == "entries")
{
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr><th>کد</th><th>ماده</th><th>مقدار</th>
                @if (Auth.CanViewPrice) { <th>قیمت</th> }
                <th>تاریخ ورود</th><th>تاریخ انقضا</th><th>ثبت‌کننده</th></tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr class="@(e.ExpiryDate<DateTime.Now?"row-warning":"")">
                        <td><code>@e.Material?.Code</code></td>
                        <td>@e.Material?.Name</td>
                        <td>@e.Quantity.ToString("N2") @e.Material?.Unit</td>
                        @if (Auth.CanViewPrice) { <td>@e.PricePerUnit.ToString("N0") ﷼</td> }
                        <td>@e.EntryDate.ToShamsi()</td>
                        <td class="@(e.ExpiryDate<DateTime.Now?"expired":e.ExpiryDate<DateTime.Now.AddDays(7)?"expiring":"")">
                            @e.ExpiryDate.ToShamsi()
                        </td>
                        <td>@e.CreatedByUsername</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="data-table">
            <thead><tr><th>کد</th><th>ماده</th><th>مقدار</th><th>تاریخ خروج</th><th>کاربر</th><th>وضعیت</th><th>تایید‌کننده</th></tr></thead>
            <tbody>
                @foreach (var w in withdrawals)
                {
                    <tr>
                        <td><code>@w.Material?.Code</code></td>
                        <td>@w.Material?.Name</td>
                        <td>@w.Quantity.ToString("N2") @w.Material?.Unit</td>
                        <td>@w.WithdrawalDate.ToShamsi()</td>
                        <td>@w.CreatedByUsername</td>
                        <td>
                            @if (w.Status==WithdrawalStatus.Pending)    { <span class="status-badge warning">در انتظار</span> }
                            else if (w.Status==WithdrawalStatus.Approved) { <span class="status-badge ok">تایید</span> }
                            else { <span class="status-badge danger">رد: @w.RejectReason</span> }
                        </td>
                        <td>@w.ApprovedByUsername</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    string tab="entries", search="";
    List<StockEntry> entries=new(); List<StockWithdrawal> withdrawals=new();

    protected override async Task OnInitializedAsync() => await Load();
    async Task OnSearch(ChangeEventArgs e) { search=e.Value?.ToString()??""; await Load(); }
    async Task Load() { entries=await Warehouse.GetEntriesAsync(search:search); withdrawals=await Warehouse.GetWithdrawalsAsync(search:search); }

    async Task ExportCsv()
    {
        var csv = new System.Text.StringBuilder();
        if (tab=="entries")
        {
            csv.AppendLine("کد,ماده,مقدار,واحد,قیمت,تاریخ ورود,تاریخ انقضا,ثبت‌کننده");
            foreach (var e in entries)
                csv.AppendLine($"{e.Material?.Code},{e.Material?.Name},{e.Quantity},{e.Material?.Unit},{e.PricePerUnit},{e.EntryDate.ToShamsi()},{e.ExpiryDate.ToShamsi()},{e.CreatedByUsername}");
        }
        else
        {
            csv.AppendLine("کد,ماده,مقدار,واحد,تاریخ خروج,کاربر,وضعیت,تایید‌کننده");
            foreach (var w in withdrawals)
                csv.AppendLine($"{w.Material?.Code},{w.Material?.Name},{w.Quantity},{w.Material?.Unit},{w.WithdrawalDate.ToShamsi()},{w.CreatedByUsername},{w.Status},{w.ApprovedByUsername}");
        }
        var bytes = System.Text.Encoding.UTF8.GetPreamble()
            .Concat(System.Text.Encoding.UTF8.GetBytes(csv.ToString())).ToArray();
        await JS.InvokeVoidAsync("downloadFile", Convert.ToBase64String(bytes),
            tab=="entries" ? "entries.csv" : "withdrawals.csv");
    }
}
